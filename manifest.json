{
  "manifest_version": 3,
  "name": "tabPureHome",
  "version": "1.1.4",
  "description": "Customize the new tab URL in the browser and How links are opened in web pages. 自定义浏览器的新标签网址和在网页中打开链接的方式。",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "./pages/index_new_tab/index_new_tab.html"
  },
  "action": {
    "default_popup": "./pages/popup/popup.html",
    "default_title": "tabPureHome"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "./common/config.js", "./common/language.js", "./common/md5.js", "./common/func.js",
        "./content/dom_a_target.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "./static/appicon-16.png",
    "32": "./static/appicon-32.png",
    "48": "./static/appicon-48.png",
    "128": "./static/appicon-128.png"
  },
  "minimum_chrome_version": "132.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "tabpurehome@datathink.top",
      "strict_min_version": "132.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}